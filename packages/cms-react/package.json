{
  "name": "@deepsel/cms-react",
  "version": "1.0.6",
  "description": "React utilities for Deepsel CMS",
  "repository": {
    "type": "git",
    "url": "https://github.com/DeepselSystems/deepsel-cms",
    "directory": "packages/cms-react"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Tim Tran <tim.tran@deepsel.com> (https://deepsel.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DeepselSystems/deepsel-cms/issues"
  },
  "homepage": "https://github.com/DeepselSystems/deepsel-cms/tree/main/packages/cms-react#readme",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ui/*": {
      "import": "./dist/ui/*.js",
      "types": "./dist/ui/*.d.ts"
    },
    "./hooks/*": {
      "import": "./dist/hooks/*.js",
      "types": "./dist/hooks/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/**/*.css\" dist",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"{src,tests}/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"{src,tests}/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepush": "npm run test && npm run build && npm run lint && npm run format:check"
  },
  "keywords": [
    "cms",
    "react",
    "deepsel",
    "typescript",
    "helper",
    "content-management"
  ],
  "dependencies": {
