---
import type { PageData } from "@deepsel/cms-utils";
import Footer from "./components/Footer.astro";
import "./main.css";
import faviconPng from "./assets/icons/favicon.png";

interface Props {
    data: PageData;
}
---

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={faviconPng.src} />
    <meta name="viewport" content="width=device-width" />
    <title>404 - Seite nicht gefunden</title>
    <meta name="description" content="Die gesuchte Seite konnte nicht gefunden werden." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="min-h-screen flex flex-col bg-white">
        <main class="flex-1 flex flex-col items-center justify-center">
            <div class="max-w-2xl mx-auto text-center px-6">
                <h1 class="text-[120px] font-bold text-[rgba(1,29,102,1)] leading-none mb-4">404</h1>
                <h2 class="text-[28px] font-semibold text-[rgba(9,20,35,1)] mb-6">Seite nicht gefunden</h2>
                <p class="text-[16px] mb-8 text-[rgba(9,20,35,0.6)]">
                    Die gesuchte Seite existiert nicht oder wurde verschoben.
                </p>
                <a
                    href="/"
                    class="inline-block px-8 py-[14px] bg-[rgba(62,105,220,1)] text-white rounded-[50px] text-[14px] font-bold hover:bg-[rgba(52,90,190,1)] transition-colors"
                >
                    Zurück zur Startseite
                </a>
            </div>
        </main>
        <Footer />
    </div>
</body>
</html>
